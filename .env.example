CADDIE_DB_USERNAME=
CADDIE_DB_PASSWORD=

# Operation Service
OPERATION_SERVER_PORT=8084
OPERATION_DB_URL=jdbc:log4jdbc:mysql://localhost:3306/fo_operation?createDatabaseIfNotExist=true&characterEncoding=UTF-8
OPERATION_DB_USERNAME=
OPERATION_DB_PASSWORD=

