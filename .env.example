# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT
JWT_SECRET_KEY=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# JPA
JPA_SHOW_SQL=true
JPA_DDL_AUTO=update

# External APIs
JUSO_API_KEY=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_FROM_NUMBER=
MAIL_USERNAME=
MAIL_PASSWORD=

# FairwayOps bootstrap settings
FAIRWAYOPS_NOTIFICATION_PUSH_FCM_ENABLED=false
FAIRWAYOPS_SCHEDULER_NOTIFICATION_CLEANUP_ENABLED=false
FAIRWAYOPS_SCHEDULER_NOTIFICATION_CLEANUP_CRON=
FAIRWAYOPS_BOOTSTRAP_MASTER_ENABLED=false
FAIRWAYOPS_MASTER_EMAIL=
FAIRWAYOPS_MASTER_PASSWORD=
FAIRWAYOPS_MASTER_NAME=
FAIRWAYOPS_MASTER_PHONE=

# Database defaults
DB_DRIVER_CLASS_NAME=net.sf.log4jdbc.sql.jdbcapi.DriverSpy
DB_POOL_MAX_SIZE=3
DB_POOL_MIN_IDLE=1

# Gateway Service
GATEWAY_SERVER_PORT=8000

# Auth Service
AUTH_SERVER_PORT=8080
AUTH_DB_URL=jdbc:log4jdbc:mysql://localhost:3306/fo_auth?createDatabaseIfNotExist=true&characterEncoding=UTF-8
AUTH_DB_USERNAME=
AUTH_DB_PASSWORD=

# Golf Course Service
GOLF_SERVER_PORT=8082
GOLF_DB_URL=jdbc:log4jdbc:mysql://localhost:3306/fo_golf?createDatabaseIfNotExist=true&characterEncoding=UTF-8
GOLF_DB_USERNAME=
GOLF_DB_PASSWORD=

